# ============================================================
# Moodle RAG Backend - Cấu hình môi trường
# Sao chép file này thành .env và điền giá trị thật
# ============================================================

# --- Server ---
# Host/port mà FastAPI lắng nghe. Plugin Moodle mặc định gọi http://localhost:8001/api/chat
APP_HOST=0.0.0.0
APP_PORT=8001

# API key mà plugin Moodle phải gửi qua header X-API-Key.
# Phải khớp với "API key" cấu hình trong Moodle (Site admin > Plugins > local_chatbot).
BACKEND_API_KEY=change-me-chatbot-secret

# --- Laravel Gateway (nguồn dữ liệu Moodle cho ingestion) ---
# Base URL trỏ tới nhóm route /api/v1/moodle của Laravel Gateway.
GATEWAY_BASE_URL=http://localhost:8000/api/v1/moodle
# API key để gọi Laravel Gateway (khớp EXTERNAL_API_KEYS trong .env của moodle-api).
GATEWAY_API_KEY=chatbot_key_123
GATEWAY_TIMEOUT=60
# URL công khai của Moodle, dùng để tạo link trích dẫn tới bài học (tuỳ chọn).
MOODLE_PUBLIC_URL=http://localhost/moodle

# --- Nhà cung cấp LLM cho phần SINH câu trả lời: "gemini" hoặc "openai" ---
# Embedding luôn dùng Gemini bất kể giá trị này.
LLM_PROVIDER=gemini

# --- OpenAI-compatible (vd NVIDIA NIM - https://build.nvidia.com) ---
# Đặt LLM_PROVIDER=openai để dùng. Lấy key nvapi-... tại build.nvidia.com
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=meta/llama-3.3-70b-instruct

# --- Google Gemini ---
# Lấy key tại https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Lưu ý free tier: gemini-2.5-flash chỉ ~20 req/ngày; gemini-2.5-flash-lite cao hơn nhiều.
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
# Model dự phòng khi model chính hết quota (mỗi model có hạn mức/ngày riêng).
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite,gemini-flash-latest
GEMINI_EMBED_MODEL=gemini-embedding-001

# --- ChromaDB ---
# Thư mục lưu vector DB (persistent).
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=moodle_content

# --- RAG tuning ---
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5
# Khoảng cách cosine tối đa để coi chunk là liên quan (lọc câu hỏi ngoài phạm vi)
RETRIEVAL_MAX_DISTANCE=0.40
# Số lượt hội thoại gần nhất giữ lại làm ngữ cảnh (mỗi lượt = 1 user + 1 bot)
MAX_HISTORY_TURNS=5
