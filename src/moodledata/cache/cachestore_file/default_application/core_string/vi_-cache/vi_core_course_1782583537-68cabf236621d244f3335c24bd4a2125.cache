a:137:{s:23:"activitychoosercategory";s:30:"Người chọn hoạt động";s:30:"activitychooserrecommendations";s:44:"Các hoạt động được khuyến khích";s:23:"activitychoosersettings";s:54:"Các thiết đặt cho người chọn hoạt động";s:27:"activitychooseractivefooter";s:23:"Activity chooser footer";s:32:"activitychooseractivefooter_desc";s:70:"The activity chooser can support plugins that add items to the footer.";s:25:"activitychooserhidefooter";s:9:"No footer";s:22:"activitychoosertabmode";s:21:"Activity chooser tabs";s:27:"activitychoosertabmode_desc";s:200:"The activity chooser lists activities and resources for a teacher to add to their course. To add items to the Recommended tab, go to <a href='../course/recommendations.php'>Recommended activities</a>.";s:25:"activitychoosertabmodeone";s:48:"Starred, All, Activities, Resources, Recommended";s:25:"activitychoosertabmodetwo";s:25:"Starred, All, Recommended";s:27:"activitychoosertabmodethree";s:43:"Starred, Activities, Resources, Recommended";s:26:"activitychoosertabmodefour";s:48:"Starred, Recommended, All, Activities, Resources";s:26:"activitychoosertabmodefive";s:25:"Starred, Recommended, All";s:25:"activitychoosertabmodesix";s:43:"Starred, Recommended, Activities, Resources";s:19:"activitydate:closed";s:7:"Closed:";s:19:"activitydate:closes";s:7:"Closes:";s:19:"activitydate:opened";s:7:"Opened:";s:18:"activitydate:opens";s:6:"Opens:";s:19:"aria:coursecategory";s:27:"Danh mục các khóa học";s:20:"aria:courseshortname";s:28:"Tên tắt của khóa học";s:15:"aria:coursename";s:16:"Tên khóa học";s:15:"aria:defaulttab";s:33:"Các hoạt động mặc định";s:14:"aria:favourite";s:37:"Khóa học được đánh dấu sao";s:18:"aria:favouritestab";s:38:"Các hoạt động được gắn sao";s:19:"aria:recommendedtab";s:44:"Các hoạt động được khuyến khích";s:20:"aria:modulefavourite";s:30:"Gắn sao {$a}  hoạt động";s:22:"browsecourseadminindex";s:49:"Browse the course administration with this index.";s:18:"browsesettingindex";s:32:"Browse settings with this index.