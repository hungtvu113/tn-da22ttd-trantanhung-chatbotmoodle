a:235:{s:7:"actions";s:13:"Hành động";s:12:"availability";s:18:"Tính hiện hữu";s:16:"cancelinstallall";s:35:"Hủy các cài đặt mới ({$a})";s:16:"cancelinstallone";s:22:"Hủy cài đặt này";s:17:"cancelinstallhead";s:46:"Đang hủy cài đặt các trình bổ trợ";s:17:"cancelinstallinfo";s:264:"The following plugins are not fully installed yet so their installation may be cancelled. To do so, the plugin folder must be removed from the server now. Make sure this is really what you want to prevent accidental data loss (such as your own code modifications).";s:20:"cancelinstallinfodir";s:16:"Xóa tệp: {$a}";s:16:"cancelupgradeall";s:24:"Hủy nâng cấp ({$a})";s:17:"cancelupgradehead";s:64:"Đang khôi phục phiên bản cũ của các trình bổ trợ";s:16:"cancelupgradeone";s:28:"Hủy bản nâng cấp này";s:15:"checkforupdates";s:36:"Kiểm tra cập nhật hiện hữu";s:19:"checkforupdateslast";s:46:"Lần kiểm tra cuối hoàn thành vào {$a}";s:23:"detectedmisplacedplugin";s:144:"Trình bổ trợ "{$a->component}" được cài đặt ở vị trí không đúng "{$a->current}", vị trí mong đợi là "{$a->expected}"";s:19:"dependencyavailable";s:9:"Có sẵn";s:15:"dependencyfails";s:12:"Thất bại";s:17:"dependencyinstall";s:11:"Cài đặt";s:21:"dependencyinstallhead";s:31:"Installing missing dependencies";s:24:"dependencyinstallmissing";s:35:"Install missing dependencies ({$a})";s:17:"dependencymissing";s:7:"Thiếu";s:21:"dependencyunavailable";s:16:"Không có sẵn";s:16:"dependencyupload";s:12:"Đăng tải";s:23:"dependencyuploadmissing";s:27:"Đăng tải các file nén";s:11:"displayname";s:22:"Tên trình bổ trợ";s:17:"err_response_curl";s:89:"Không thể lấy dữ liệu cập nhật hiện hữu - lỗi cURL không mong muốn.";s:27:"err_response_format_version";s:120:"Phiên bản định dạng phản hồi không mong muốn. Hãy thử kiểm tra lại các cập nhật hiện hữu.";s:22:"err_response_http_code";s:108:"Không thể lấy dữ liệu cập nhật hiện hữu - mã nguồn phản hồi HTTP không mong muốn.";s:9:"filterall";s:17:"Hiện tất cả";s:17:"filtercontribonly";s:45:"Chỉ hiện các trình bổ trợ bổ sung";s:17:"filterupdatesonly";s:35:"Chỉ hiện có thể cập nhật";s:19:"incompatibleversion";s:47:"Phiên bản Moodle không tương thích: {$a}";s:9:"isenabled";s:29:"Được kích hoạt không?";s:16:"misdepinfoplugin";s:28:"Thông tin trình bổ trợ";s:17:"misdepinfoversion";s:23:"Thông tin phiên bản";s:12:"misdepsavail";s:30:"Available missing dependencies";s:14:"misdepsunavail";s:32:"Unavailable missing dependencies";s:18:"misdepsunavaillist";s:62:"No version found to fulfill the dependency requirements: {$a}.";s:18:"misdepsunknownlist";s:52:"Not in the Plugins directory: <strong>{$a}</strong>.";s:12:"moodlebranch";s:28:"Moodle {$a->min} - {$a->max}";s:13:"moodleversion";s:11:"Moodle {$a}";s:13:"noneinstalled";s:66:"Không có các trình bổ trợ loại này được cài đặt";s:5:"notes";s:8:"Ghi chú";s:15:"notdownloadable";s:23:"Không thể tải gói";s:20:"notdownloadable_help";s:123:"Gói ZIP với bản cập nhật không thể tải về tự động. Hãy xem trang tài liệu để thêm trợ giúp.";s:20:"notdownloadable_link";s:29:"admin/mdeploy/notdownloadable";s:12:"notsupported";s:80:"Trình bổ trợ có thể không tương thích với phiên bản Moodle {$a}";s:11:"notwritable";s:52:"Các tập tin trình bổ trợ không ghi được";s:16:"notwritable_help";s:457:"Bạn đã kích hoạt triển khai tự động cập nhật và có một bản cập nhật cho trình bổ trợ này. Tuy nhiên, các tập tin trình bổ trợ không thể ghi được bởi máy chủ web vì vậy bản cập nhật không thể được cài đặt tự động.

Bạn cần làm cho thư mục trình bổ trợ và tất cả nội dung của nó có thể ghi được để có thể cài đặt cập nhật tự động.";s:11:"otherplugin";s:15:"{$a->component}";s:18:"otherpluginversion";s:31:"{$a->component} ({$a->version})";s:11:"overviewall";s:33:"Tất cả các trình bổ trợ";s:11:"overviewext";s:32:"Các trình bổ trợ bổ sung";s:17:"overviewupdatable";s:33:"Các bản cập nhật có sẵn";s:13:"packagesdebug";s:24:"Debugging output enabled";s:19:"packagesdownloading";s:21:"Đang tải về {$a}";s:18:"packagesextracting";s:25:"Đang chiết xuất {$a}";s:18:"packagesvalidating";s:22:"Đang đánh giá {$a}";s:24:"packagesvalidatingfailed";s:59:"Hủy cài đặt vì thất bại trong việc đánh giá";s:20:"packagesvalidatingok";s:50:"Đánh giá thành công, tiếp tục cài đặt";s:14:"plugincheckall";s:33:"Tất cả các trình bổ trợ";s:20:"plugincheckattention";s:39:"Những trình bổ trợ cần chú ý";s:15:"pluginchecknone";s:68:"Không có trình bổ trợ nào yêu cầu sự chú ý từ bạn";s:17:"pluginchecknotice";s:585:"Trang này hiển thị các trình bổ trợ yêu cầu sự chú ý của bạn trong quá trình nâng cấp, bao gồm các trình bổ trợ mới mà bạn định cài đặt, các trình bổ trợ sắp được nâng cấp và bất kì trình bổ trợ còn thiếu nào. Các trình bổ trợ bổ sung sẽ hiển thị nếu có bản cập nhật cho chúng. Khuyến khích bạn kiểm tra liệu có các phiên bản trình bổ trợ gần đây hơn không và cập nhật mã nguồn của chúng trước khi tiếp tục với bản nâng cấp Moodle này.";s:13:"plugindisable";s:15:"Vô hiệu hóa";s:14:"plugindisabled";s:20:"Bị vô hiệu hóa";s:12:"pluginenable";s:12:"Kích hoạt";s:13:"pluginenabled";s:21:"Được kích hoạt";s:7:"release";s:11:"Phát hành";s:10:"requiredby";s:31:"Được yêu cầu bởi: {$a}";s:8:"requires";s:10:"Yêu cầu";s:7:"rootdir";s:10:"Thư mục";s:8:"settings";s:13:"Thiết lập";s:6:"source";s:7:"Nguồn";s:9:"sourceext";s:9:"Bổ sung";s:9:"sourcestd";s:7:"Chuẩn";s:6:"status";s:13:"Trạng thái";s:13:"status_delete";s:16:"Sắp sửa xóa";s:16:"status_downgrade";s:48:"Phiên bản cao hơn đã được cài đặt!";s:14:"status_missing";s:33:"Không có trong ổ đĩa cứng";s:10:"status_new";s:23:"Sắp sửa cài đặt";s:11:"status_nodb";s:11:"Không CSDL";s:14:"status_upgrade";s:23:"Sắp sửa nâng cấp";s:15:"status_uptodate";s:20:"Được cài đặt";s:23:"supportedmoodleversions";s:44:"Các phiên bản Moodle được hỗ trợ";s:20:"supportedconversions";s:30:"Supported document conversions";s:10:"systemname";s:12:"Định danh";s:14:"type_antivirus";s:31:"Trình bổ trợ chống virus";s:21:"type_antivirus_plural";s:36:"Các trình bổ trợ chống virus";s:9:"type_auth";s:27:"Phương thức xác thực";s:16:"type_auth_plural";s:30:"Phương thức chứng thực";s:17:"type_availability";s:25:"Giới hạn hiện hữu";s:24:"type_availability_plural";s:30:"Các giới hạn hiện hữu";s:10:"type_block";s:6:"Khối";s:17:"type_block_plural";s:6:"Khối";s:14:"type_cachelock";s:37:"Trình kiểm soát khóa bộ đệm";s:21:"type_cachelock_plural";s:42:"Các trình kiểm soát khóa bộ đệm";s:15:"type_cachestore";s:22:"Lưu trữ bộ đệm";s:22:"type_cachestore_plural";s:22:"Lưu trữ bộ đệm";s:17:"type_calendartype";s:13:"Loại lịch";s:24:"type_calendartype_plural";s:18:"Các loại lịch";s:18:"type_communication";s:22:"Communication provider";s:25:"type_communication_plural";s:23:"Communication providers";s:16:"type_contenttype";s:12:"Content bank";s:23:"type_contenttype_plural";s:20:"Content bank plugins";s:16:"type_contentbank";s:22:"Ngân hành nội dung";s:23:"type_contentbank_plural";s:45:"Các trình bổ trợ ngân hàng nội dung";s:16:"type_customfield";s:12:"Custom field";s:23:"type_customfield_plural";s:13:"Custom fields";s:17:"type_coursereport";s:21:"Báo cáo khóa học";s:24:"type_coursereport_plural";s:26:"Các báo cáo khóa học";s:15:"type_dataformat";s:24:"Hình thức dữ liệu";s:22:"type_dataformat_plural";s:29:"Các hình thức dữ liệu";s:11:"type_editor";s:20:"Trình soạn thảo";s:18:"type_editor_plural";s:25:"Các trình soạn thảo";s:10:"type_enrol";s:24:"Phương thức ghi danh";s:17:"type_enrol_plural";s:29:"Các phương thức ghi danh";s:18:"type_fileconverter";s:18:"Document converter";s:24:"type_fileconvertermanage";s:26:"Manage document converters";s:25:"type_fileconverter_plural";s:19:"Document converters";s:11:"type_filter";s:21:"Bộ lọc văn bản";s:18:"type_filter_plural";s:21:"Bộ lọc văn bản";s:11:"type_format";s:26:"Định dạng khóa học";s:18:"type_format_plural";s:31:"Các định dạng khoá học";s:16:"type_gradeexport";s:30:"Phương thức xuất điểm";s:23:"type_gradeexport_plural";s:35:"Các phương thức xuất điểm";s:16:"type_gradeimport";s:30:"Phương thức nhập điểm";s:23:"type_gradeimport_plural";s:35:"Các phương thức nhập điểm";s:16:"type_gradereport";s:22:"Báo cáo sổ điểm";s:23:"type_gradereport_plural";s:27:"Các báo cáo sổ điểm";s:16:"type_gradingform";s:40:"Phương thức chấm điểm nâng cao";s:23:"type_gradingform_plural";s:45:"Các phương thức chấm điểm nâng cao";s:11:"type_h5plib";s:13:"H5P framework";s:18:"type_h5plib_plural";s:14:"H5P frameworks";s:14:"type_mlbackend";s:24:"Machine learning backend";s:21:"type_mlbackend_plural";s:25:"Machine learning backends";s:10:"type_local";s:28:"Trình bổ trợ cục bộ";s:17:"type_local_plural";s:33:"Các trình bổ trợ cục bộ";s:10:"type_media";s:12:"Media player";s:17:"type_media_plural";s:13:"Media players";s:12:"type_message";s:21:"Đầu ra thông báo";s:19:"type_message_plural";s:26:"Các đầu ra thông báo";s:16:"type_mnetservice";s:16:"Dịch vụ MNet";s:23:"type_mnetservice_plural";s:21:"Các dịch vụ MNet";s:8:"type_mod";s:21:"Module hoạt động";s:15:"type_mod_plural";s:28:"Các mô-đun hoạt động";s:16:"type_paygwmanage";s:23:"Manage payment gateways";s:10:"type_paygw";s:15:"Payment gateway";s:17:"type_paygw_plural";s:16:"Payment gateways";s:15:"type_plagiarism";s:37:"Trình bổ trợ chống đạo văn";s:22:"type_plagiarism_plural";s:42:"Các trình bổ trợ chống đạo văn";s:14:"type_portfolio";s:14:"Cặp hồ sơ";s:21:"type_portfolio_plural";s:19:"Các cặp hồ sơ";s:17:"type_profilefield";s:21:"Loại mục hồ sơ";s:24:"type_profilefield_plural";s:26:"Các loại mục hồ sơ";s:15:"type_qbehaviour";s:19:"Hành vi câu hỏi";s:22:"type_qbehaviour_plural";s:24:"Các hành vi câu hỏi";s:12:"type_qformat";s:39:"Định dạng nhập/xuất câu hỏi";s:19:"type_qformat_plural";s:44:"Các định dạng nhập/xuất câu hỏi";s:10:"type_qtype";s:17:"Loại câu hỏi";s:17:"type_qtype_plural";s:22:"Các loại câu hỏi";s:11:"type_report";s:15:"Báo cáo trang";s:18:"type_report_plural";s:14:"Các báo cáo";s:15:"type_repository";s:3:"Kho";s:22:"type_repository_plural";s:27:"Các kho chứa dữ liệu";s:11:"type_search";s:22:"Công cụ tìm kiếm";s:18:"type_search_plural";s:27:"Các công cụ tìm kiếm";s:10:"type_theme";s:11:"Giao diện";s:17:"type_theme_plural";s:11:"Giao diện";s:9:"type_tool";s:23:"Công cụ quản trị";s:16:"type_tool_plural";s:28:"Các công cụ quản trị";s:15:"type_webservice";s:27:"Giao thức dịch vụ web";s:22:"type_webservice_plural";s:32:"Các giao thức dịch vụ web";s:10:"type_qbank";s:20:"Question bank plugin";s:17:"type_qbank_plural";s:21:"Question bank plugins";s:15:"updateavailable";s:40:"Phiên bản {$a} mới đang có sẵn!";s:24:"updateavailable_moreinfo";s:19:"Thêm thông tin...";s:23:"updateavailable_release";s:10:"Nhả {$a}";s:19:"updatepluginconfirm";s:41:"Xác nhận nâng cấp trình bổ trợ";s:23:"updatepluginconfirminfo";s:273:"You are about to install a new version of the plugin <strong>{$a->name}</strong>. A zip package with version {$a->version} of the plugin will be downloaded from <a href="{$a->url}">{$a->url}</a> and extracted to your Moodle installation so it can upgrade your installation.";s:27:"updatepluginconfirmexternal";s:317:"It appears that the current version of the plugin has been obtained via source code management system ({$a}) checkout. If you install this update, you will no longer be able to obtain plugin updates from the source code management system. Please ensure that you definitely want to update the plugin before continuing.";s:26:"updatepluginconfirmwarning";s:305:"Please note that Moodle will not automatically make a backup of your database before the upgrade. We strongly recommend that you make a full snapshot backup now, to cope with the rare case that the new code has bugs that make your site unavailable or even corrupts your database. Proceed at your own risk.";s:9:"uninstall";s:17:"Hủy cài đặt";s:16:"uninstallconfirm";s:538:"Bạn sắp hủy cài đặt trình bổ trợ <em>{$a->name}</em>. Điều này sẽ dẫn tới việc xóa toàn bộ mọi thứ trong CSDL liên quan tới trình bổ trợ này, bao gồm các thiết đặt, các bản lưu, các file của người dùng mà được quản lí bới trình bổ trợ,... Sẽ không có bất kì cách nào để đảo ngược quá trình và tự thân Moodle cũng không tạo bất kì bản dự phòng để phục hồi dữ liệu. Bạn có thực sự muốn tiếp tục không?";s:15:"uninstalldelete";s:281:"All data associated with the plugin <em>{$a->name}</em> has been deleted from the database. To prevent the plugin re-installing itself, its folder <em>{$a->rootdir}</em> must be manually removed from your server now. Moodle itself cannot remove the folder due to write permissions.";s:22:"uninstalldeleteconfirm";s:329:"Toàn bộ dữ liệu liên quan tới trình bổ trợ  <em>{$a->name}</em> đã bị xóa khởi CSDL. Để ngăn không cho trình bổ trợ tự cài đặt lại, phải xóa thư mục của nỏ <em>{$a->rootdir}</em> khỏi máy chủ của bạn. Bạn có muốn xóa thư mục trình bổ trợ bây giờ không?";s:30:"uninstalldeleteconfirmexternal";s:293:"It appears that the current version of the plugin has been obtained via source code management system ({$a}) checkout. If you remove the plugin folder, you may lose important local modifications of the code. Please ensure that you definitely want to remove the plugin folder before continuing.";s:26:"uninstallextraconfirmblock";s:51:"There are {$a->instances} instances of this block.";s:26:"uninstallextraconfirmenrol";s:45:"Có {$a->enrolments} ghi danh người dùng.";s:24:"uninstallextraconfirmmod";s:77:"There are {$a->instances} instances of this module in {$a->courses} courses.";s:12:"uninstalling";s:35:"Đang hủy cài đặt  {$a->name}";s:28:"validationmsg_componentmatch";s:19:"Full component name";s:35:"validationmsg_componentmismatchname";s:36:"Tên trình bổ trợ không khớp";s:40:"validationmsg_componentmismatchname_help";s:181:"Some ZIP packages, such as those generated by Github, may contain an incorrect root directory name. You need to fix the name of the root directory to match the declared plugin name.";s:40:"validationmsg_componentmismatchname_info";s:94:"The plugin declares its name is '{$a}' but that does not match the name of the root directory.";s:35:"validationmsg_componentmismatchtype";s:38:"Loại trình bổ trợ không khớp";s:40:"validationmsg_componentmismatchtype_info";s:81:"Expected type '{$a->expected}' but the plugin declares its type is '{$a->found}'.";s:27:"validationmsg_filenotexists";s:45:"Không tìm thấy file được dẫn xuất";s:25:"validationmsg_filesnumber";s:40:"Không tìm thấy đủ file trong gói";s:24:"validationmsg_filestatus";s:46:"Không thể dẫn xuất tất cả các file";s:29:"validationmsg_filestatus_info";s:71:"Attempting to extract file {$a->file} resulted in error '{$a->status}'.";s:27:"validationmsg_foundlangfile";s:28:"Tìm thấy file ngôn ngữ";s:22:"validationmsg_maturity";s:23:"Declared maturity level";s:27:"validationmsg_maturity_help";s:249:"The plugin can declare its maturity level. If the maintainer considers the plugin stable, the declared maturity level will read MATURITY_STABLE. All other maturity levels (such as alpha or beta) should be considered unstable and a warning is raised.";s:30:"validationmsg_missingcomponent";s:42:"Plugin does not declare its component name";s:35:"validationmsg_missingcomponent_help";s:116:"All plugins must provide their full component name via the `$plugin->component` declaration in the version.php file.";s:35:"validationmsg_missingcomponent_link";s:23:"Development:version.php";s:39:"validationmsg_missingexpectedlangenfile";s:35:"English language file name mismatch";s:44:"validationmsg_missingexpectedlangenfile_info";s:73:"The given plugin type is missing the expected English language file {$a}.";s:31:"validationmsg_missinglangenfile";s:30:"No English language file found";s:33:"validationmsg_missinglangenfolder";s:31:"Missing English language folder";s:28:"validationmsg_missingversion";s:35:"Plugin does not declare its version";s:31:"validationmsg_missingversionphp";s:41:"Không tìm thấy file phiên bản .php";s:33:"validationmsg_multiplelangenfiles";s:37:"Multiple English language files found";s:20:"validationmsg_onedir";s:46:"Cấu trúc không hợp lệ của gói nén.";s:25:"validationmsg_onedir_help";s:147:"The ZIP package must contain just one root directory that holds the plugin code. The name of that root directory must match the name of the plugin.";s:26:"validationmsg_pathwritable";s:18:"Write access check";s:27:"validationmsg_pluginversion";s:29:"Phiên bản tình bổ trợ";s:33:"validationmsg_pluginversiontoolow";s:56:"Đã cài đặt phiên bản trình bổ trợ cao hơn";s:21:"validationmsg_release";s:14:"Plugin release";s:28:"validationmsg_requiresmoodle";s:39:"Phiên bản Moodle được yêu cầu";s:21:"validationmsg_rootdir";s:55:"Tên của trình bổ trợ sắp được cài đặt";s:26:"validationmsg_rootdir_help";s:208:"The name of the root directory in the ZIP package forms the name of the plugin to be installed. If the name is not correct, you may wish to rename the root directory in the ZIP prior to installing the plugin.";s:28:"validationmsg_rootdirinvalid";s:40:"Tên trình bổ trợ không hợp lệ";s:33:"validationmsg_rootdirinvalid_help";s:259:"The name of the root directory in the ZIP package violates formal syntax requirements. Some ZIP packages, such as those generated by Github, may contain an incorrect root directory name. You need to fix the name of the root directory to match the plugin name.";s:26:"validationmsg_targetexists";s:50:"Target location already exists and will be removed";s:31:"validationmsg_targetexists_help";s:88:"The plugin directory already exists and will be replaced by the plugin package contents.";s:26:"validationmsg_targetnotdir";s:34:"Target location occupied by a file";s:25:"validationmsg_unknowntype";s:35:"Không rõ loại trình bổ trợ";s:30:"validationmsg_versionphpsyntax";s:47:"Unsupported syntax detected in version.php file";s:24:"validationmsglevel_debug";s:9:"Vá lỗi";s:24:"validationmsglevel_error";s:5:"Lỗi";s:23:"validationmsglevel_info";s:2:"OK";s:26:"validationmsglevel_warning";s:11:"Cảnh báo";s:7:"version";s:12:"Phiên bản";s:9:"versiondb";s:25:"Phiên bản hiện tại";s:11:"versiondisk";s:18:"Phiên bản mới";}