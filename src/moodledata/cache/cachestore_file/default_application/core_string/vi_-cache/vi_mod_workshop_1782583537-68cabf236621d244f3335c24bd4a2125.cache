a:420:{s:29:"activitydate:assessmentsclose";s:29:"Bài đánh giá kết thúc:";s:30:"activitydate:assessmentsclosed";s:34:"Bài đánh giá đã kết thúc:";s:28:"activitydate:assessmentsopen";s:30:"Bài đánh giá bắt đầu:";s:30:"activitydate:assessmentsopened";s:35:"Bài đánh giá đã bắt đầu:";s:29:"activitydate:submissionsclose";s:19:"Ngừng gửi bài:";s:30:"activitydate:submissionsclosed";s:24:"Đã ngừng gửi bài:";s:28:"activitydate:submissionsopen";s:21:"Cho phép gửi bài:";s:30:"activitydate:submissionsopened";s:39:"Đã bắt đầu cho phép gửi bài:";s:15:"aggregategrades";s:19:"Tính lại điểm";s:11:"aggregation";s:20:"Tổng hợp điểm";s:8:"allocate";s:23:"Phân phối bài nộp";s:15:"allocatedetails";s:89:"expected: {$a->expected}<br />submitted: {$a->submitted}<br />to allocate: {$a->allocate}";s:10:"allocation";s:23:"Phân phối bài nộp";s:14:"allocationdone";s:25:"Hoàn thành phân phối";s:15:"allocationerror";s:18:"Lỗi phân phối";s:20:"allocationconfigured";s:21:"Allocation configured";s:34:"allowedfiletypesforoverallfeedback";s:68:"Các dạng file đính kèm được dùng trong phần nhận xét";s:39:"allowedfiletypesforoverallfeedback_help";s:229:"Các dạng file đính kèm trong phần nhận xét có thể bị giới hạn bởi danh sách những dạng file được cho phép. Nếu trường này để trống thì tất cả các dạng file đều được dùng.";s:39:"allowedfiletypesforoverallfeedback_link";s:26:"admin/tool/filetypes/index";s:29:"allowedfiletypesforsubmission";s:67:"Các dạng file đính kèm được dùng trong phần gửi bài";s:34:"allowedfiletypesforsubmission_help";s:228:"Các dạng file đính kèm trong phần gửi bài có thể bị giới hạn bởi danh sách những dạng file được cho phép. Nếu trường này để trống thì tất cả các dạng file đều được dùng.";s:34:"allowedfiletypesforsubmission_link";s:26:"admin/tool/filetypes/index";s:14:"allsubmissions";s:33:"Toàn bộ các bài nộp ({$a})";s:13:"alreadygraded";s:28:"Đã được chấm điểm";s:14:"areaconclusion";s:23:"Văn bản tổng kết";s:19:"areainstructauthors";s:25:"Hướng dẫn gửi bài";s:21:"areainstructreviewers";s:26:"Hướng dẫn đánh giá";s:29:"areaoverallfeedbackattachment";s:56:"Các file đính kèm cho phần đánh giá tổng quan";s:26:"areaoverallfeedbackcontent";s:50:"Các văn bản cho phần đánh giá tổng quan";s:24:"areasubmissionattachment";s:22:"Nộp file đính kèm";s:21:"areasubmissioncontent";s:16:"Nộp văn bản";s:6:"assess";s:11:"Đánh giá";s:15:"assessedexample";s:33:"Đã đánh giá bài nộp mẫu";s:18:"assessedsubmission";s:27:"Đã đánh giá bài nộp";s:16:"assessingexample";s:34:"Đang đánh giá bài nộp mẫu";s:19:"assessingsubmission";s:28:"Đang đánh giá bài nộp";s:10:"assessment";s:11:"Đánh giá";s:12:"assessmentby";s:40:"bởi <a href="{$a->url}">{$a->name}</a>";s:20:"assessmentbyfullname";s:22:"Đánh giá bởi {$a}";s:20:"assessmentbyyourself";s:23:"Đánh giá của bạn";s:17:"assessmentdeleted";s:22:"Assessment deallocated";s:13:"assessmentend";s:34:"Hạn chót cho phần đánh giá";s:24:"assessmentendbeforestart";s:104:"Hạn chót cho phần đánh giá không thể được định trước ngày bắt đầu đánh giá";s:18:"assessmentendevent";s:39:"{$a} hạn chót cho phần đánh giá";s:21:"assessmentenddatetime";s:73:"Hạn chót cho phần đánh giá: {$a->daydatetime} ({$a->distanceday})";s:14:"assessmentform";s:17:"Mẫu đánh giá";s:22:"assessmentofsubmission";s:103:"<a href="{$a->assessmenturl}">Assessment</a> of <a href="{$a->submissionurl}">{$a->submissiontitle}</a>";s:19:"assessmentreference";s:20:"Reference assessment";s:27:"assessmentreferenceconflict";s:97:"It is not possible to assess an example submission for which you provided a reference assessment.";s:25:"assessmentreferenceneeded";s:127:"You have to assess this example submission to provide a reference assessment. Click 'Continue' button to assess the submission.";s:11:"assessments";s:21:"Các bài đánh giá";s:18:"assessmentsettings";s:31:"Các thiết đặt đánh giá";s:15:"assessmentstart";s:34:"Bắt đầu đánh già kể từ";s:20:"assessmentstartevent";s:29:"{$a} bắt đầu đánh giá";s:23:"assessmentstartdatetime";s:72:"Bắt đầu đánh già kể từ {$a->daydatetime} ({$a->distanceday})";s:16:"assessmentweight";s:17:"Assessment weight";s:19:"assignedassessments";s:47:"Các bài nộp được giao để đánh giá";s:23:"assignedassessmentsnone";s:64:"Bạn không có bài nộp được giao nào để đánh giá";s:14:"backtoeditform";s:37:"Trở về phần chỉnh sửa mẫu";s:10:"byfullname";s:40:"bởi <a href="{$a->url}">{$a->name}</a>";s:21:"byfullnamewithoutlink";s:10:"bởi {$a}";s:22:"calculategradinggrades";s:25:"Tính điểm đánh giá";s:29:"calculategradinggradesdetails";s:58:"expected: {$a->expected}<br />calculated: {$a->calculated}";s:25:"calculatesubmissiongrades";s:24:"Tính điểm bài nộp";s:32:"calculatesubmissiongradesdetails";s:58:"expected: {$a->expected}<br />calculated: {$a->calculated}";s:21:"clearaggregatedgrades";s:45:"Xóa hết các điểm được tổng hợp";s:26:"clearaggregatedgrades_help";s:159:"The aggregated grades for submission and grades for assessment will be reset. You can re-calculate these grades from scratch in Grading evaluation phase again.";s:16:"clearassessments";s:21:"Xóa các đánh giá";s:21:"clearassessments_help";s:259:"The calculated grades for submission and grades for assessment will be reset. The information how the assessment forms are filled is still kept, but all the reviewers must open the assessment form again and re-save it to get the given grades calculated again.";s:23:"clearassessmentsconfirm";s:175:"Are you sure you want to clear all assessment grades? You will not be able to get the information back on your own, reviewers will have to re-assess the allocated submissions.";s:28:"clearaggregatedgradesconfirm";s:115:"Bạn có thực sự muốn xóa hết điểm đã tính cho phần bài nộp và cho phần đánh giá không?";s:10:"conclusion";s:12:"Tổng kết";s:15:"conclusion_help";s:103:"Hiển thị văn bản tổng kết đối với người tham gia sau khi hoạt động kết thúc.";s:18:"configexamplesmode";s:98:"Chế độ mặc định cho phần đánh giá mẫu trong các buổi hội thảo chủ đề.";s:11:"configgrade";s:94:"Mặc định điểm tối đa cho các bài làm tại các buổi hội thảo chủ đề.";s:19: