a:31:{s:14:"configdndmedia";s:96:"Cho phép tạo nhãn khi các file truyền thông được kéo & thả vào một khóa học";s:21:"configdndresizeheight";s:206:"Khi một nhãn dán được tạo bởi một hình ảnh kéo & thả thì hãy chỉnh kích thước của nó nếu cao hơn từng này độ phân giải (0 là không phải chỉnh kích thước)";s:20:"configdndresizewidth";s:209:"Khi một nhãn dán được tạo bởi một hình ảnh kéo & thả thì hãy chỉnh kích thước của nó nếu rộng hơn từng này độ phân giải (0 là không phải chỉnh kích thước)";s:8:"dndmedia";s:19:"Media drag and drop";s:15:"dndresizeheight";s:53:"Sửa kích thước của chiều cao kéo và thả";s:14:"dndresizewidth";s:56:"Sửa kích thước của chiều rộng kéo và thả";s:14:"dnduploadlabel";s:24:"Add media to course page";s:18:"dnduploadlabeltext";s:50:"Thêm một nhãn dãn cho trang của khóa học";s:24:"indicator:cognitivedepth";s:29:"Text and media area cognitive";s:29:"indicator:cognitivedepth_help";s:104:"This indicator is based on the cognitive depth reached by the student in a Text and media area resource.";s:27:"indicator:cognitivedepthdef";s:29:"Text and media area cognitive";s:32:"indicator:cognitivedepthdef_help";s:171:"The participant has reached this percentage of the cognitive engagement offered by the Text and media area resources during this analysis interval (Levels = No view, View)";s:32:"indicator:cognitivedepthdef_link";s:45:"Learning_analytics_indicators#Cognitive_depth";s:23:"indicator:socialbreadth";s:26:"Text and media area social";s:28:"indicator:socialbreadth_help";s:103:"This indicator is based on the social breadth reached by the student in a Text and media area resource.";s:26:"indicator:socialbreadthdef";s:26:"Text and media area social";s:31:"indicator:socialbreadthdef_help";s:190:"The participant has reached this percentage of the social engagement offered by the Text and media area resources during this analysis interval (Levels = No participation, Participant alone)";s:31:"indicator:socialbreadthdef_link";s:44:"Learning_analytics_indicators#Social_breadth";s:17:"label:addinstance";s:23:"Thêm một nhãn mới";s:10:"label:view";s:9:"Xem nhãn";s:9:"labelname";s:21:"Title in course index";s:14:"labelname_help";s:211:"The title is only used to identify the Text and media area in the course index and for activity completion. If you leave it empty,  a title will be automatically generated using the first characters of the text.";s:9:"labeltext";s:23:"Nhãn kiểu văn bản";s:10:"modulename";s:5:"Nhãn";s:15:"modulename_help";s:308:"The Text and media area enables you to display text and multimedia on the course page.

You can use a Text and media area to:

* Split up a long list of course activities with a subheading or an image
* Display an embedded video directly on the course page
* Add a short description to a course section";s:15:"modulename_link";s:14:"mod/label/view";s:16:"modulenameplural";s:10:"Các nhãn";s:16:"privacy:metadata";s:71:"Trình bổ trợ nguồn nhãn không lưu trữ dữ liệu cá nhân";s:20:"pluginadministration";s:16:"Quản lí nhãn";s:10:"pluginname";s:5:"Nhãn";s:15:"search:activity";s:5:"Nhãn";}