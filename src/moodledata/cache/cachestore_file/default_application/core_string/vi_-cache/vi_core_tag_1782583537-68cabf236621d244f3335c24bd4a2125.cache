20:"Mô tả của thẻ";s:25:"privacy:metadata:tag:flag";s:48:"Whether a tag has been flagged as inappropriate.";s:33:"privacy:metadata:tag:timemodified";s:48:"Thời điểm chỉnh sửa thẻ lần cuối.";s:27:"privacy:metadata:tag:userid";s:30:"ID người dùng tạo thẻ.";s:28:"privacy:metadata:taginstance";s:64:"Đường dẫn giữa các thẻ và nơi chúng đươc dùng.";s:34:"privacy:metadata:taginstance:tagid";s:28:"Đường dẫn tới thẻ.";s:37:"privacy:metadata:taginstance:ordering";s:31:"The relative order of this tag.";s:40:"privacy:metadata:taginstance:timecreated";s:48:"The time that this tag was linked to the target.";s:41:"privacy:metadata:taginstance:timemodified";s:51:"The time that this tag was modified for the target.";s:37:"privacy:metadata:taginstance:tiuserid";s:98:"Where shared content can be individually tagged by users, the owner of the tag instance is stored.";s:5:"ptags";s:78:"Các thẻ người dùng tự định nghĩa (Ngăn cách bởi dấu phẩy)";s:12:"relatedblogs";s:34:"Các mục blog gần đây nhất";s:11:"relatedtags";s:21:"Các thẻ liên quan";s:24:"removetagfrommyinterests";s:41:"Xóa "{$a}" khỏi sở thích của tôi";s:5:"reset";s:23:"Đặt lại cờ thẻ";s:11:"resetfilter";s:23:"Đặt lại bộ lọc";s:9:"resetflag";s:17:"Đặt lại cờ";s:25:"responsiblewillbenotified";s:56:"Người chịu trách nhiệm sẽ được thông báo";s:7:"rssdesc";s:124:"Dòng tin RSS này được tự động tạo bởi Moodle và chứa các thẻ người dùng tạo cho các khóa học.";s:8:"rsstitle";s:61:"Dòng tin RSS các thẻ khóa học cho người dùng: {$a}";s:12:"showstandard";s:31:"Cách dùng thẻ tiêu chuẩn";s:17:"showstandard_help";s:229:"Khi nhập thẻ, có thể thẻ tiêu chuẩn sẽ được gợi ý hoặc ép phải dùng, nghĩa là không được nhập thẻ mới. Hoặc, được nhập thẻ mới mà không có gợi ý dùng thẻ tiêu chuẩn.";s:6:"search";s:11:"Tìm kiếm";s:10:"searchable";s:23:"Có thể tìm được";s:15:"searchable_help";s:241:"Nếu được tích chọn, thẻ ở trong bộ sưu tập tìm kiếm này có thể được tìm thấy thông qua trang "Tìm thẻ". Nếu không, chúng vẫn có thể được tìm thấy thông qua những trang tìm kiếm khác.";s:16:"searchresultsfor";s:43:"Kết quả tìm kiếm đối với "{$a}"";s:10:"searchtags";s:22:"Các thẻ tìm kiếm";s:11:"seeallblogs";s:56:"Xem tất cả mục blog được gắn thẻ "{$a}"...";s:6:"select";s:6:"Chọn";s:10:"selectcoll";s:28:"Chọn bộ sưu tập thẻ";s:13:"selectmaintag";s:52:"Chọn thẻ sẽ được dùng sau khi kết hợp";s:18:"selectmultipletags";s:40:"Xin hãy chọn nhiều hơn một thẻ";s:9:"selecttag";s:17:"Chọn thẻ {$a}";s:14:"settypedefault";s:31:"Xóa khỏi thẻ tiêu chuẩn";s:15:"settypestandard";s:19:"Tạo tiêu chuẩn";s:16:"showingfirsttags";s:43:"Hiển thị {$a} thẻ phổ biến nhất";s:13:"standardforce";s:12:"Bắt buộc";s:12:"standardhide";s:15:"Không gợi ý";s:15:"standardsuggest";s:8:"Gợi ý";s:11:"standardtag";s:13:"Tiêu chuẩn";s:14:"suredeletecoll";s:71:"Bạn có thực sự muốn xóa bộ sưu tập thẻ  "{$a}" không?";s:3:"tag";s:5:"Thẻ";s:7:"tagarea";s:8:"Tag area";s:21:"tagarea_blog_external";s:19:"External blog posts";s:12:"tagarea_post";s:10:"Blog posts";s:12:"tagarea_user";s:32:"Sở thích của người dùng";s:14:"tagarea_course";s:16:"Các khóa học";s:22:"tagarea_course_modules";s:31:"Các hoạt động và nguồn";s:11:"tagarea_tag";s:12:"Related tags";s:14:"tagareaenabled";s:21:"Được kích hoạt";s:11:"tagareaname";s:4:"Tên";s:8:"tagareas";s:29:"Những khu vực gắn thẻ";s:9:"tagauthor";s:10:"Tag author";s:13:"tagcollection";s:21:"Bộ sưu tập thẻ";s:18:"tagcollection_help";s:414:"Tag collections are sets of tags for different areas. For example, a collection of standard tags can be used to tag courses, with user interests and blog post tags kept in a separate collection. When a user clicks on a tag, the tag page displays only items with that tag in the same collection. Tags can be automatically added to a collection according to the area tagged or can be added manually as standard tags.";s:14:"tagcollections";s:29:"Những bộ sưu tập thẻ";s:14:"tagdescription";s:14:"Mô tả thẻ";s:11:"taginstance";s:12:"Tag instance";s:4:"tags";s:5:"Thẻ";s:15:"tagsaredisabled";s:31:"Các thẻ bị vô hiệu hóa