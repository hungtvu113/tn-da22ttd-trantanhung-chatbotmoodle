a:23:{s:8:"addgroup";s:16:"Thêm vào nhóm";s:10:"coursesort";s:34:"Sắp xếp danh sách khóa học";s:15:"coursesort_help";s:330:"Tính năng này  quyết định danh sách các khóa học có thể được liên kết sẽ được lọc theo thứ tự (ví dụ: thứ tự được cài đặt trong quản trị trang > các khóa học > quản lí các khóa học và các danh mục) hoặc theo bảng chữ cái bởi thiết đặt khóa học.";s:11:"creategroup";s:17:"Tạo nhóm mới";s:20:"defaultgroupnametext";s:38:"{$a->name} khóa học {$a->increment}";s:17:"enrolmetasynctask";s:24:"Meta enrolment sync task";s:12:"linkedcourse";s:26:"Đường link khóa học";s:11:"meta:config";s:30:"Configure meta enrol instances";s:19:"meta:selectaslinked";s:28:"Select course as meta linked";s:12:"meta:unenrol";s:57:"Hủy đăng kí những người dùng bị đình chỉ";s:13:"nosyncroleids";s:47:"Các vai trò không được đồng bộ hóa";s:18:"nosyncroleids_desc";s:96:"Select any roles that should not be synchronised between the source course to the target course.";s:10:"pluginname";s:16:"Course meta link";s:15:"pluginname_desc";s:99:"The course meta link synchronises enrolments and roles from the source course to the target course.";s:7:"syncall";s:65:"Đồng bộ hóa toàn bộ những người dùng đã ghi danh";s:14:"samemetacourse";s:45:"You can't add a meta link to the same course.";s:12:"syncall_desc";s:324:"Nếu kích hoạt thì toàn bộ người dùng đã ghi danh sẽ được đồng bộ hóa kể cả khi họ không có vai trò gì trong khóa học mẹ. Nếu vô hiệu hóa thì chỉ có những người dùng mà có ít  nhất một vai trò được đồng bộ sẽ được ghi danh vào khóa học con.";s:27:"privacy:metadata:core_group";s:129:"The course meta link enrolment plugin can create a new group or use an existing group to add participants from the source course.";s:17:"unknownmetacourse";s:29:"Unknown meta course shortname";s:19:"wscannotcreategroup";s:57:"No permission to create group in linked course id = {$a}.";s:15:"wsinvalidcourse";s:86:"Course ID = {$a} doesn't exist or you don't have permission to add a course meta link.";s:19:"wsinvalidmetacourse";s:94:"Meta course ID = {$a} doesn't exist or you don't have permission to add an enrolment instance.";s:22:"wsnoinstancesspecified";s:22:"No instances specified";}