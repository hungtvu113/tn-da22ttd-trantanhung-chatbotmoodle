a:26:{s:10:"pluginname";s:35:"Trợ lý học tập (Chatbot RAG)";s:15:"settings_apiurl";s:24:"Địa chỉ Backend RAG";s:20:"settings_apiurl_desc";s:102:"URL đầy đủ tới endpoint /chat của backend Python (ví dụ: http://localhost:8001/api/chat).";s:15:"settings_apikey";s:7:"API Key";s:20:"settings_apikey_desc";s:71:"Khoá bí mật để xác thực giữa Moodle plugin và backend RAG.";s:16:"settings_enabled";s:13:"Bật chatbot";s:21:"settings_enabled_desc";s:64:"Hiển thị nút chat nổi trên tất cả các trang Moodle.";s:16:"settings_timeout";s:38:"Thời gian chờ phản hồi (giây)";s:21:"settings_timeout_desc";s:71:"Số giây tối đa chờ backend trả lời trước khi báo lỗi.";s:22:"task_deadline_reminder";s:39:"Nhắc nhở deadline sắp hết hạn";s:21:"task_overdue_reminder";s:50:"Nhắc sinh viên chưa nộp bài khi hết hạn";s:21:"task_teacher_followup";s:50:"Nhắc giáo viên hoàn thiện khóa học mới";s:11:"chatbot:use";s:42:"Sử dụng chatbot hỗ trợ học tập";s:12:"widget_title";s:21:"Trợ lý học tập";s:15:"widget_subtitle";s:26:"Hỗ trợ bởi AI · RAG";s:18:"widget_placeholder";s:53:"Hỏi tôi về khoá học, tài liệu, deadline...";s:11:"widget_send";s:5:"Gửi";s:11:"widget_open";s:26:"Mở trợ lý học tập";s:12:"widget_close";s:6:"Đóng";s:14:"widget_welcome";s:128:"Xin chào! Tôi có thể giúp bạn tra cứu khoá học, tài liệu, deadline và điểm số. Bạn cần hỗ trợ gì?";s:15:"widget_thinking";s:18:"Đang suy nghĩ...";s:12:"widget_error";s:58:"Xin lỗi, đã có lỗi xảy ra. Vui lòng thử lại.";s:14:"widget_sources";s:19:"Nguồn tham khảo";s:32:"privacy:metadata:chatbot_backend";s:124:"Plugin chatbot gửi câu hỏi của người dùng tới backend RAG bên ngoài để xử lý và sinh câu trả lời.";s:39:"privacy:metadata:chatbot_backend:userid";s:92:"ID người dùng Moodle được gửi tới backend để cá nhân hoá câu trả lời.";s:40:"privacy:metadata:chatbot_backend:message";s:72:"Nội dung câu hỏi của người dùng được gửi tới backend.";}